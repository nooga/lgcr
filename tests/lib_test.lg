;; Unit tests for lib.lg — pure helpers only.
;; Run with: letgo tests/lib_test.lg  (from project root)

(ns lgcr.lib-test
  (:require [lib :as lib]
            [test :as test :refer [deftest is testing run-tests]]))

;; ---------------------------------------------------------------------------
;; pad-right
;; ---------------------------------------------------------------------------

(deftest pad-right-basic
  (is (= "hi   " (lib/pad-right "hi" 5)))
  (is (= "already-long" (lib/pad-right "already-long" 3)))
  (is (= "" (lib/pad-right "" 0))))

;; ---------------------------------------------------------------------------
;; short-id
;; ---------------------------------------------------------------------------

(deftest short-id-takes-12-chars
  (is (= "0123456789ab"
         (lib/short-id "0123456789abcdef0123456789abcdef"))))

;; ---------------------------------------------------------------------------
;; numeric?
;; ---------------------------------------------------------------------------

(deftest numeric?-digits-only
  (is (= true  (lib/numeric? "0")))
  (is (= true  (lib/numeric? "1000")))
  (is (= false (lib/numeric? "")))
  (is (= false (lib/numeric? "12a")))
  (is (= false (lib/numeric? "abc")))
  (is (= false (lib/numeric? nil))))

;; ---------------------------------------------------------------------------
;; parse-memory-size
;; ---------------------------------------------------------------------------

(deftest parse-memory-size-suffixes
  (is (= "1024" (lib/parse-memory-size "1k")))
  (is (= "536870912" (lib/parse-memory-size "512m")))
  (is (= "1073741824" (lib/parse-memory-size "1g"))))

(deftest parse-memory-size-passes-through-plain-values
  (is (= "max" (lib/parse-memory-size "max")))
  (is (= "1048576" (lib/parse-memory-size "1048576"))))

;; ---------------------------------------------------------------------------
;; strip-nils
;; ---------------------------------------------------------------------------

(deftest strip-nils-drops-nil-entries
  (is (= [] (lib/strip-nils [])))
  (is (= [] (lib/strip-nils nil)))
  (is (= [1 2 3] (lib/strip-nils [1 nil 2 nil 3])))
  (is (= ["a"] (lib/strip-nils [nil "a" nil]))))

;; ---------------------------------------------------------------------------
;; split-short-flags
;; ---------------------------------------------------------------------------

(deftest split-short-flags-splits-combined
  (is (= ["-a" "-b" "-c"]       (lib/split-short-flags ["-abc"])))
  (is (= ["-a" "-q"]             (lib/split-short-flags ["-aq"])))
  (is (= ["-a"]                  (lib/split-short-flags ["-a"])))
  (is (= ["--rm"]                (lib/split-short-flags ["--rm"])))
  (is (= ["arg" "-d"]            (lib/split-short-flags ["arg" "-d"])))
  (is (= ["-a" "--rm" "-d" "-f"] (lib/split-short-flags ["-a" "--rm" "-df"])))
  (is (= [] (lib/split-short-flags []))))

;; ---------------------------------------------------------------------------
;; path helpers
;; ---------------------------------------------------------------------------

(deftest path-dirname-various
  (is (= "/" (lib/path-dirname "/work")))
  (is (= "/work" (lib/path-dirname "/work/file.txt")))
  (is (= "/work/nested" (lib/path-dirname "/work/nested/file.txt")))
  (is (= "." (lib/path-dirname "file.txt"))))

;; ---------------------------------------------------------------------------
;; env-has-key? / merge-env
;; ---------------------------------------------------------------------------

(deftest env-has-key?-matches-prefix
  (is (= true  (lib/env-has-key? ["PATH=/bin" "HOME=/root"] "PATH")))
  (is (= true  (lib/env-has-key? ["FOO=bar"] "FOO")))
  (is (= false (lib/env-has-key? ["PATHX=y"] "PATH")))
  (is (= false (lib/env-has-key? [] "PATH"))))

(deftest merge-env-user-overrides-image
  (let [image ["PATH=/bin" "HOME=/root"]
        user  ["HOME=/home/me"]
        out   (lib/merge-env image user)]
    (is (some #(= "HOME=/home/me" %) out)
        "user HOME should appear")
    (is (not (some #(= "HOME=/root" %) out))
        "image HOME should be suppressed")
    (is (some #(= "PATH=/bin" %) out)
        "image PATH survives when user doesnt override")))

(deftest merge-env-adds-path-fallback
  (let [out (lib/merge-env [] [])]
    (is (some #(lib/env-has-key? [%] "PATH") out)
        "PATH fallback injected when neither side set it")))

(deftest merge-env-drops-nils
  (let [out (lib/merge-env [nil "PATH=/bin"] [nil "HOME=/root"])]
    (is (not (some nil? out))
        "no nil entries remain in merged env")))

;; ---------------------------------------------------------------------------
;; parse-image-ref
;; ---------------------------------------------------------------------------

(deftest parse-image-ref-short-name
  (let [{:keys [registry repo tag]} (lib/parse-image-ref "alpine")]
    (is (= "registry-1.docker.io" registry))
    (is (= "library/alpine" repo) "docker hub short names get library/ prefix")
    (is (= "latest" tag) "default tag is latest")))

(deftest parse-image-ref-with-tag
  (let [{:keys [registry repo tag]} (lib/parse-image-ref "alpine:3.21")]
    (is (= "library/alpine" repo))
    (is (= "3.21" tag))))

(deftest parse-image-ref-user-namespaced
  (let [{:keys [repo tag]} (lib/parse-image-ref "bitnami/postgres:16")]
    (is (= "bitnami/postgres" repo) "already-namespaced repos keep their org")
    (is (= "16" tag))))

(deftest parse-image-ref-custom-registry
  (let [{:keys [registry repo tag]} (lib/parse-image-ref "ghcr.io/owner/app:v1")]
    (is (= "ghcr.io" registry))
    (is (= "owner/app" repo))
    (is (= "v1" tag))))

;; ---------------------------------------------------------------------------
;; image-rootfs-dir
;; ---------------------------------------------------------------------------

(deftest image-subdir-slashes-become-underscores
  (is (= "library_alpine-3.21"
         (lib/image-subdir {:repo "library/alpine" :tag "3.21"}))))

(deftest image-rootfs-dir-joins-root
  (is (= "/var/lib/lgcr/images/library_alpine-3.21"
         (lib/image-rootfs-dir "/var/lib/lgcr/images"
                               {:repo "library/alpine" :tag "3.21"}))))

;; ---------------------------------------------------------------------------
;; compose-command
;; ---------------------------------------------------------------------------

(def throw-err
  (fn [m] (throw (str "compose-err: " m))))

(deftest compose-command-user-cmd-prepended-with-entrypoint
  (let [[c a] (lib/compose-command
                {:entrypoint ["/docker-entrypoint.sh"]
                 :cmd ["nginx" "-g" "daemon off;"]}
                "cat" ["/etc/passwd"]
                throw-err)]
    (is (= "/docker-entrypoint.sh" c))
    (is (= ["cat" "/etc/passwd"] a)
        "user cmd overrides CMD, ENTRYPOINT still prepends")))

(deftest compose-command-no-user-uses-cmd-default
  (let [[c a] (lib/compose-command
                {:entrypoint [] :cmd ["/bin/sh"]}
                nil nil
                throw-err)]
    (is (= "/bin/sh" c))
    (is (= [] a))))

(deftest compose-command-entrypoint-plus-cmd
  (let [[c a] (lib/compose-command
                {:entrypoint ["/ep"] :cmd ["default-arg"]}
                nil nil
                throw-err)]
    (is (= "/ep" c))
    (is (= ["default-arg"] a))))

(deftest compose-command-strips-nils-from-entrypoint
  (let [[c a] (lib/compose-command
                {:entrypoint [nil] :cmd ["/bin/sh"]}
                nil nil
                throw-err)]
    (is (= "/bin/sh" c))
    (is (= [] a) "nil entrypoint stripped cleanly")))

;; ---------------------------------------------------------------------------
;; bind mount parsing
;; ---------------------------------------------------------------------------

(deftest parse-volume-mount-rw
  (is (= {:type "bind" :src "/host" :dst "/work" :readonly? false}
         (lib/parse-mount-spec "/host:/work" throw-err))))

(deftest parse-volume-mount-ro
  (is (= {:type "bind" :src "/host/file" :dst "/etc/file" :readonly? true}
         (lib/parse-mount-spec "/host/file:/etc/file:ro" throw-err))))

(deftest parse-long-mount-rw
  (is (= {:type "bind" :src "/host" :dst "/work" :readonly? false}
         (lib/parse-mount-spec "type=bind,src=/host,dst=/work" throw-err))))

(deftest parse-long-mount-readonly
  (is (= {:type "bind" :src "/host" :dst "/work" :readonly? true}
         (lib/parse-mount-spec "type=bind,source=/host,target=/work,readonly" throw-err))))

(deftest parse-mount-specs-accumulates
  (is (= [{:type "bind" :src "/a" :dst "/x" :readonly? false}
          {:type "bind" :src "/b" :dst "/y" :readonly? true}]
         (lib/parse-mount-specs ["/a:/x" "/b:/y:ro"] throw-err))))

(deftest valid-mount-dst-rejects-unsafe
  (is (= true  (lib/valid-mount-dst? "/work")))
  (is (= true  (lib/valid-mount-dst? "/work/nested")))
  (is (= false (lib/valid-mount-dst? "/")))
  (is (= false (lib/valid-mount-dst? "work")))
  (is (= false (lib/valid-mount-dst? "/work/../host"))))

;; ---------------------------------------------------------------------------
;; tmpfs mount parsing
;; ---------------------------------------------------------------------------

(deftest parse-tmpfs-spec-defaults-options
  (is (= {:dst "/cache" :opts "mode=1777"}
         (lib/parse-tmpfs-spec "/cache" throw-err))))

(deftest parse-tmpfs-spec-keeps-options
  (is (= {:dst "/cache" :opts "size=64m,mode=0755,noexec"}
         (lib/parse-tmpfs-spec "/cache:size=64m,mode=0755,noexec" throw-err))))

(deftest parse-tmpfs-specs-accumulates
  (is (= [{:dst "/cache" :opts "mode=1777"}
          {:dst "/run/app" :opts "mode=0755"}]
         (lib/parse-tmpfs-specs ["/cache" "/run/app:mode=0755"] throw-err))))

;; ---------------------------------------------------------------------------
;; network parsing
;; ---------------------------------------------------------------------------

(deftest parse-network-spec-defaults-to-host
  (is (= {:type :host} (lib/parse-network-spec nil throw-err))))

(deftest parse-network-spec-known-drivers
  (is (= {:type :host} (lib/parse-network-spec "host" throw-err)))
  (is (= {:type :none} (lib/parse-network-spec "none" throw-err)))
  (is (= {:type :bridge :name "lgcr0"}
         (lib/parse-network-spec "bridge" throw-err))))

;; ---------------------------------------------------------------------------
;; published port parsing
;; ---------------------------------------------------------------------------

(deftest parse-publish-spec-basic
  (is (= {:host-port 8080 :container-port 80 :proto "tcp"}
         (lib/parse-publish-spec "8080:80" throw-err))))

(deftest parse-publish-specs-accumulates
  (is (= [{:host-port 8080 :container-port 80 :proto "tcp"}
          {:host-port 8443 :container-port 443 :proto "tcp"}]
         (lib/parse-publish-specs ["8080:80" "8443:443"] throw-err))))

;; ---------------------------------------------------------------------------
;; security parsing
;; ---------------------------------------------------------------------------

(deftest parse-seccomp-spec-defaults-to-default
  (is (= "default" (lib/parse-seccomp-spec nil throw-err))))

(deftest parse-seccomp-spec-known-values
  (is (= "default" (lib/parse-seccomp-spec "default" throw-err)))
  (is (= "unconfined" (lib/parse-seccomp-spec "unconfined" throw-err))))

(deftest parse-apparmor-profile-defaults-to-nil
  (is (= nil (lib/parse-apparmor-profile nil throw-err))))

(deftest parse-apparmor-profile-known-values
  (is (= nil (lib/parse-apparmor-profile "unconfined" throw-err)))
  (is (= "profile-name" (lib/parse-apparmor-profile "profile-name" throw-err))))

;; ---------------------------------------------------------------------------
;; parse-signal
;; ---------------------------------------------------------------------------

(deftest parse-signal-defaults-to-term
  (is (= 15 (lib/parse-signal nil throw-err))))

(deftest parse-signal-accepts-names
  (is (= 9  (lib/parse-signal "KILL" throw-err)))
  (is (= 9  (lib/parse-signal "SIGKILL" throw-err)))
  (is (= 15 (lib/parse-signal "TERM" throw-err)))
  (is (= 2  (lib/parse-signal "INT" throw-err)))
  (is (= 28 (lib/parse-signal "WINCH" throw-err))))

(deftest parse-signal-accepts-numbers
  (is (= 7 (lib/parse-signal "7" throw-err))))

;; ---------------------------------------------------------------------------
;; capabilities
;; ---------------------------------------------------------------------------

(deftest parse-capability-normalizes-prefix
  (is (= "NET_ADMIN" (lib/parse-capability "NET_ADMIN" throw-err)))
  (is (= "NET_ADMIN" (lib/parse-capability "cap_net_admin" throw-err)))
  (is (= "ALL" (lib/parse-capability "all" throw-err))))

(deftest resolve-capabilities-default-add-drop
  (let [base (lib/resolve-capabilities nil nil throw-err)]
    (is (= true  (lib/vector-contains? base "NET_RAW")))
    (is (= false (lib/vector-contains? base "NET_ADMIN"))))
  (let [caps (lib/resolve-capabilities ["NET_ADMIN"] ["NET_RAW"] throw-err)]
    (is (= true  (lib/vector-contains? caps "NET_ADMIN")))
    (is (= false (lib/vector-contains? caps "NET_RAW")))))

(deftest resolve-capabilities-all-and-bounding-drops
  (is (= ["NET_BIND_SERVICE"]
         (lib/resolve-capabilities ["NET_BIND_SERVICE"] ["ALL"] throw-err)))
  (let [drops (lib/bounding-drop-capabilities [])]
    (is (= "SETPCAP" (last drops)))
    (is (= true (lib/vector-contains? drops "CHOWN")))))

(deftest capability-mask-combines-bits
  (is (= 8193 (lib/capability-mask ["CHOWN" "NET_RAW"]))))

;; ---------------------------------------------------------------------------
;; humanize-ago
;; ---------------------------------------------------------------------------

(deftest format-tenths-drops-zero-fraction
  (is (= "1" (lib/format-tenths 10)))
  (is (= "3.1" (lib/format-tenths 31)))
  (is (= "0.7" (lib/format-tenths 7))))

(deftest humanize-bytes-various
  (is (= "?"      (lib/humanize-bytes nil)))
  (is (= "0B"     (lib/humanize-bytes 0)))
  (is (= "512B"   (lib/humanize-bytes 512)))
  (is (= "1kB"    (lib/humanize-bytes 1024)))
  (is (= "3.1kB"  (lib/humanize-bytes 3200)))
  (is (= "1MB"    (lib/humanize-bytes 1048576)))
  (is (= "7.7MB"  (lib/humanize-bytes 8100000)))
  (is (= "1GB"    (lib/humanize-bytes 1073741824))))

(deftest humanize-ago-various
  (is (= "just now"      (lib/humanize-ago -1)))
  (is (= "0 seconds"     (lib/humanize-ago 0)))
  (is (= "1 second"      (lib/humanize-ago 1)))
  (is (= "59 seconds"    (lib/humanize-ago 59)))
  (is (= "1 minute"      (lib/humanize-ago 60)))
  (is (= "2 minutes"     (lib/humanize-ago 120)))
  (is (= "1 hour"        (lib/humanize-ago 3600)))
  (is (= "3 hours"       (lib/humanize-ago 10800)))
  (is (= "1 day"         (lib/humanize-ago 86400)))
  (is (= "5 days"        (lib/humanize-ago (* 5 86400)))))

;; ---------------------------------------------------------------------------
;; format-cmd
;; ---------------------------------------------------------------------------

(deftest format-cmd-joins-args
  (is (= "sleep 30"
         (lib/format-cmd {:command "sleep" :args ["30"]})))
  (is (= "echo"
         (lib/format-cmd {:command "echo" :args []})))
  (is (= "sh -c echo hi"
         (lib/format-cmd {:command "sh" :args ["-c" "echo hi"]}))))

(deftest merge-http-opts-keeps-base-headers
  (is (= {:as :stream
          :headers {"Accept" "application/json"
                    "Authorization" "Bearer tok"}}
         (lib/merge-http-opts {:headers {"Accept" "application/json"
                                         "Authorization" "Bearer tok"}}
                              {:as :stream})))
  (is (= {:headers {"Accept" "application/json"
                    "Authorization" "Bearer tok"
                    "Range" "bytes=10-"}}
         (lib/merge-http-opts {:headers {"Accept" "application/json"
                                         "Authorization" "Bearer tok"}}
                              {:headers {"Range" "bytes=10-"}})))
  (is (= {:headers {"Accept" "application/json"
                    "Authorization" "Bearer tok"}}
         (lib/merge-http-opts {:headers {"Accept" "application/json"
                                         "Authorization" "Bearer tok"}}
                              {:headers nil}))))

;; ---------------------------------------------------------------------------
;; render-status
;; ---------------------------------------------------------------------------

(deftest render-status-running
  (is (= "Up 5 seconds"
         (lib/render-status
           {:effective-status "running" :started-epoch 95}
           100))))

(deftest render-status-exited
  (is (= "Exited (0) 30 seconds ago"
         (lib/render-status
           {:effective-status "exited" :exit-code 0 :finished-epoch 70}
           100))))

(deftest render-status-killed-with-signal
  (is (= "Killed (signal 15) 5 seconds ago"
         (lib/render-status
           {:effective-status "killed" :signal 15 :finished-epoch 95}
           100))))

(deftest render-status-created
  (is (= "Created"
         (lib/render-status {:effective-status "created"} 100))))

;; ---------------------------------------------------------------------------
;; parse-flags
;; ---------------------------------------------------------------------------

(def RUN-SPEC
  {"-d"   [:detached?  :bool]
   "--rm" [:rm?        :bool]
   "-t"   [:tty?       :bool]
   "-i"   [:_i         :ignore]
   "-p"   [:publish    :accumulate]
   "--publish" [:publish :accumulate]
   "-e"   [:extra-env  :accumulate]})

(deftest parse-flags-empty
  (is (= [{} []] (lib/parse-flags RUN-SPEC []))))

(deftest parse-flags-single-bool
  (is (= [{:detached? true} []] (lib/parse-flags RUN-SPEC ["-d"]))))

(deftest parse-flags-multiple-bool
  (is (= [{:detached? true :rm? true} []]
         (lib/parse-flags RUN-SPEC ["-d" "--rm"]))))

(deftest parse-flags-stops-at-positional
  (is (= [{:detached? true} ["alpine" "/bin/sh"]]
         (lib/parse-flags RUN-SPEC ["-d" "alpine" "/bin/sh"]))))

(deftest parse-flags-stops-at-unknown
  (is (= [{:detached? true} ["--unknown" "x"]]
         (lib/parse-flags RUN-SPEC ["-d" "--unknown" "x"]))))

(deftest parse-flags-ignore-consumed-not-stored
  (let [[f xs] (lib/parse-flags RUN-SPEC ["-i" "-t" "rest"])]
    (is (= {:tty? true} f))
    (is (= ["rest"] xs))))

(deftest parse-flags-combined-short
  ;; -it splits to -i (ignore) + -t (bool)
  (is (= [{:tty? true} ["alpine"]]
         (lib/parse-flags RUN-SPEC ["-it" "alpine"]))))

(deftest parse-flags-accumulate
  (is (= [{:extra-env ["A=1" "B=2"]} ["alpine"]]
         (lib/parse-flags RUN-SPEC ["-e" "A=1" "-e" "B=2" "alpine"]))))

(deftest parse-flags-publish-accumulates
  (is (= [{:publish ["8080:80" "8443:443"]} ["alpine"]]
         (lib/parse-flags RUN-SPEC ["-p" "8080:80" "--publish=8443:443" "alpine"]))))

(deftest parse-flags-value
  (is (= [{:signal "TERM"} ["abc"]]
         (lib/parse-flags {"-s" [:signal :value]} ["-s" "TERM" "abc"]))))

(deftest parse-flags-long-inline-value
  (is (= [{:network "none"} ["alpine"]]
         (lib/parse-flags {"--net" [:network :value]}
                          ["--net=none" "alpine"]))))

(deftest parse-flags-long-inline-accumulate
  (is (= [{:tmpfs ["/cache" "/run:mode=0755"]} ["alpine"]]
         (lib/parse-flags {"--tmpfs" [:tmpfs :accumulate]}
                          ["--tmpfs=/cache" "--tmpfs=/run:mode=0755" "alpine"]))))

(deftest parse-flags-int
  (is (= [{:grace 30} ["abc"]]
         (lib/parse-flags {"-t" [:grace :int]} ["-t" "30" "abc"]))))

(deftest parse-flags-long-flag
  (is (= [{:containers? true :images? true} []]
         (lib/parse-flags {"--containers" [:containers? :bool]
                           "--images"     [:images? :bool]}
                          ["--containers" "--images"]))))

(deftest parse-flags-mixed-kinds
  (is (= [{:detached? true :rm? true :extra-env ["X=1"] :tty? true}
          ["img" "cmd" "arg"]]
         (lib/parse-flags RUN-SPEC
                          ["-d" "--rm" "-e" "X=1" "-it" "img" "cmd" "arg"]))))

(deftest parse-flags-no-flags-just-positional
  (is (= [{} ["alpine" "sh"]]
         (lib/parse-flags RUN-SPEC ["alpine" "sh"]))))

(deftest parse-flags-flag-after-positional-stays-positional
  ;; once we hit a non-flag, the rest is positional even if it looks like a flag
  (is (= [{} ["cmd" "-d"]]
         (lib/parse-flags RUN-SPEC ["cmd" "-d"]))))

;; ---------------------------------------------------------------------------
;; main
;; ---------------------------------------------------------------------------

(run-tests)
(when-not test/*test-result* (os/exit 1))
